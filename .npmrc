; Hoist solo los paquetes que Gradle necesita resolver via Node.js require()
; No usa node-linker=hoisted (eso rompe Next.js)
; Solo crea symlinks adicionales en root node_modules para estos paquetes:
public-hoist-pattern[]=@react-native/gradle-plugin
public-hoist-pattern[]=@react-native/community-cli-platform-android
public-hoist-pattern[]=@react-native-community/cli-platform-android
