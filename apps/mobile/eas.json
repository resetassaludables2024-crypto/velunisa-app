{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r23c",
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r23c",
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://velunisa.com"
      }
    },
    "local": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.12:3000"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r23c",
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://velunisa.com"
      }
    },
    "production-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      }
    },
    "velunisa-go": {
      "distribution": "internal",
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r23c",
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://velunisa.com",
        "EXPO_PUBLIC_APP_VARIANT": "go"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
