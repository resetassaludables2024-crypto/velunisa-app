# ============================================================
# VELUNISA — Variables de Entorno
# Copia este archivo a .env.local y completa los valores
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------
# Desarrollo local (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# Producción (PostgreSQL en Railway / Neon / PlanetScale):
# DATABASE_URL="postgresql://user:password@host:5432/velunisa"

# ------------------------------------------------------------
# NEXT.JS / APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3001"
# En producción: NEXT_PUBLIC_APP_URL="https://velunisa.com"

# ------------------------------------------------------------
# NEXTAUTH
# ------------------------------------------------------------
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-super-seguro-aqui"
NEXTAUTH_URL="http://localhost:3001"
# En producción: NEXTAUTH_URL="https://velunisa.com"

# ------------------------------------------------------------
# GOOGLE OAUTH (para login con Google)
# Crea en: https://console.cloud.google.com/apis/credentials
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ------------------------------------------------------------
# ANTHROPIC (Claude AI — Chat Luna + Captions)
# Obtén en: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# ------------------------------------------------------------
# CLOUDINARY (subida de imágenes)
# Obtén en: https://cloudinary.com/console
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="velunisa"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="velunisa"

# ------------------------------------------------------------
# RESEND (emails transaccionales)
# Obtén en: https://resend.com/api-keys
# Configura dominio: https://resend.com/domains
# ------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="pedidos@velunisa.com"

# ------------------------------------------------------------
# WHATSAPP (notificaciones)
# Usa Twilio WhatsApp Sandbox o API de Meta
# ------------------------------------------------------------
WHATSAPP_API_URL="https://api.twilio.com/..."   # o tu proveedor
WHATSAPP_API_TOKEN=""
NEXT_PUBLIC_WHATSAPP_NUMBER="+593XXXXXXXXX"     # número de WhatsApp de la tienda

# ------------------------------------------------------------
# BANCO (datos para pantalla de transferencia)
# ------------------------------------------------------------
BANK_NAME="Banco Pichincha"
BANK_ACCOUNT_NUMBER="2207654321"
BANK_ACCOUNT_OWNER="Velunisa S.A."
BANK_ACCOUNT_TYPE="Corriente"
BANK_RUC="0912345678001"

# ------------------------------------------------------------
# PAYMENTEZ / NUVEI (pago con tarjeta — opcional)
# Crea tu cuenta en: https://paymentez.com
# Panel: https://dashboard.paymentez.com
# ------------------------------------------------------------
# Claves del SERVIDOR (secretas — solo en el servidor)
PAYMENTEZ_SERVER_APP_CODE=""
PAYMENTEZ_SERVER_APP_KEY=""

# Claves del CLIENTE (públicas — expuestas en el frontend)
NEXT_PUBLIC_PAYMENTEZ_CLIENT_APP_CODE=""
NEXT_PUBLIC_PAYMENTEZ_CLIENT_APP_KEY=""

# Entorno: "stg" para pruebas, "prod" para producción
NEXT_PUBLIC_PAYMENTEZ_ENV="stg"

# ------------------------------------------------------------
# INSTAGRAM GRAPH API (publicaciones programadas)
# Obtén en: https://developers.facebook.com/
# Requiere cuenta de Instagram Business conectada
# ------------------------------------------------------------
META_ACCESS_TOKEN=""
META_INSTAGRAM_USER_ID=""

# ------------------------------------------------------------
# TIKTOK API (publicaciones programadas)
# Obtén en: https://developers.tiktok.com/
# ------------------------------------------------------------
TIKTOK_ACCESS_TOKEN=""
TIKTOK_OPEN_ID=""

# ------------------------------------------------------------
# CRON SECRET (protege /api/social/process-queue)
# Genera con: openssl rand -hex 32
# Configura el mismo valor en Vercel → Settings → Cron Jobs
# ------------------------------------------------------------
CRON_SECRET="tu-cron-secret-aqui"

# ------------------------------------------------------------
# EXPO (app móvil — push notifications)
# Obtén en: https://expo.dev/accounts/[usuario]/settings/access-tokens
# ------------------------------------------------------------
EXPO_ACCESS_TOKEN=""   # opcional — aumenta rate limit de push
